---
export const links = [
  { href: '/', label: '首页' },
  { href: '/download', label: '下载' },
  { href: '/docs/', label: '文档' },
  { href: '/about', label: '关于' },
];
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 text-lg font-bold">
      <img src="/logo.svg" alt="Qomicex" class="h-7 w-auto" />
      Qomicex Launcher
    </a>
    <nav>
      <ul class="flex items-center gap-1">
        {links.map(link => (
          <li>
            <a href={link.href} class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
