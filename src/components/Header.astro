---
const links = [
  { href: '/', label: '首页' },
  { href: '/download', label: '下载' },
  { href: '/tutorial', label: '教程' },
  { href: '/about', label: '关于' },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 text-lg font-bold">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="9" height="9" rx="1.5" fill="var(--color-primary)" />
        <rect x="13" y="2" width="9" height="9" rx="1.5" fill="var(--color-primary)" opacity="0.7" />
        <rect x="2" y="13" width="9" height="9" rx="1.5" fill="var(--color-primary)" opacity="0.5" />
        <rect x="13" y="13" width="9" height="9" rx="1.5" fill="var(--color-primary)" opacity="0.3" />
      </svg>
      Qomicex
    </a>
    <nav>
      <ul class="flex items-center gap-1">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class="rounded-md px-3 py-1.5 text-sm text-[var(--color-muted-fg)] transition-colors hover:text-[var(--color-fg)]"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
