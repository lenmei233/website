---
import { updatedAt } from '../data/last-fetch.json';
import { t, type Lang } from '../i18n';

const lang = Astro.props.lang as Lang
const base = lang === 'en' ? '/en' : ''
---

<footer class="border-t border-border">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-x-4 gap-y-1 px-4 py-5 text-xs text-muted-foreground">
    <span>{t('footer.copyright', lang)}</span>
    <a href="https://github.com/Qomicex-Public" target="_blank" class="inline-flex items-center gap-1 hover:text-foreground transition-colors">GitHub</a>
    <a href="https://qm.qq.com/q/rKiwzrkg8w" target="_blank" class="inline-flex items-center gap-1 hover:text-foreground transition-colors">{t('footer.qq', lang)}</a>
    <a href={lang === 'en' ? 'https://www.patreon.com/cw/JunSi_233' : 'https://afdian.com/a/QomicexLauncher'} target="_blank" class="inline-flex items-center gap-1 hover:text-foreground transition-colors">{t('footer.afdian', lang)}</a>
    <a href={`${base}/about`} class="hover:text-foreground transition-colors">{t('footer.about', lang)}</a>
    <a href={`${base}/legal/user-agreement`} class="hover:text-foreground transition-colors">{t('footer.agreement', lang)}</a>
    <span class="text-muted-foreground/60">{t('footer.dataUpdated', lang)} {updatedAt.slice(0, 10)}</span>
  </div>
</footer>
