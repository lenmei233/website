---
import Base from '../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { MIRRORS } from '../../data/mirrors.ts';
import releases from '../../data/releases.json';
import { t, langFromPath, carouselWords, getFeatures } from '../../i18n';

const lang = langFromPath(Astro.url.pathname)
const stable = releases.find(r => !r.prerelease)
const pre = releases.find(r => r.prerelease)
const stableTag = stable?.tagName ?? ''
const preTag = pre?.tagName ?? ''
const stableAssets = stable?.assets ?? []
const preAssets = pre?.assets ?? []
const hasPre = !!pre
const verDisplay = stable ? `v${stable.version}` : pre ? `v${pre.version}${lang === 'en' ? ' (Preview)' : ' (测试版)'}` : ''

const features = getFeatures(lang)

const partners = [
  { img: '/services/curseforge.png', name: 'CurseForge' },
  { img: '/services/modrinth.svg', name: 'Modrinth' },
  { img: '/services/ftb.png', name: 'FTB' },
  { img: '/services/mcmod.png', name: 'MC百科' },
  { img: '/services/bangbang93.png', name: 'BangBang93' },
]
---

<Base>
  <section class="hero-section relative flex min-h-screen items-center justify-center overflow-hidden">
    <div class="hero-bg">
      <div class="hero-grid"></div>
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
    </div>
    <div class="relative z-10 mx-auto flex max-w-lg flex-col items-center px-4 py-24 text-center sm:py-32">

      <img src="/high_logo.svg" alt="QML启动器" class="mb-6 w-full max-w-xs" />

      {verDisplay && (
        <span class="mb-4 inline-flex items-center gap-1.5 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-green-400">
          <Icon name="lucide:tag" class="size-3" />
          {verDisplay} · {lang === 'en' ? 'All Platforms' : '全平台'}
        </span>
      )}

      <p class="hero-desc mb-8 max-w-sm text-sm text-slate-300">
        {t('hero.desc', lang)}
        <span class="carousel-word" id="carousel-word">{carouselWords[lang][0]}</span>
      </p>

      <button id="dl-btn" class="inline-flex h-14 w-full max-w-xs cursor-pointer items-center justify-center gap-2.5 rounded-xl bg-green-500 text-base font-semibold text-white shadow-lg shadow-green-500/30 transition-all hover:bg-green-400 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-green-400/40 active:scale-[0.98]">
        <Icon name="lucide:download" class="size-5" />{stable ? t('dl.stable', lang) : t('dl.download', lang)}
      </button>

      <div class="mt-5 flex items-center gap-3 text-xs text-slate-400 sm:gap-4">
        <span class="inline-flex items-center gap-1.5"><Icon name="fa6-brands:windows" class="size-3.5" />Windows</span>
        <span class="inline-flex items-center gap-1.5"><Icon name="fa6-brands:apple" class="size-3.5" />macOS</span>
        <span class="inline-flex items-center gap-1.5"><Icon name="lucide:terminal" class="size-3.5" />Linux</span>
        {hasPre && <>
          <span class="text-slate-500">|</span>
          <button id="dl-pre-btn" class="cursor-pointer text-slate-400 underline underline-offset-2 transition-colors hover:text-white">{t('dl.pre', lang)}</button>
        </>}
      </div>
    </div>
  </section>

  <!-- Features full-bleed blocks -->
  <section class="relative">
    {features.map((f, i) => (
      <div class={`relative ${i % 2 === 1 ? 'bg-gradient-to-r from-transparent via-primary/[0.015] to-transparent' : ''}`}>
        <div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-4 py-20 sm:flex-row sm:py-28 lg:gap-16">
          <div class={`w-full sm:w-1/2 ${f.reversed ? 'sm:order-2' : ''}`}>
            <div data-animate class="mb-4">
              <span class="inline-flex size-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <Icon name={['lucide:layout-dashboard', 'lucide:layers', 'lucide:users', 'lucide:file-stack', 'lucide:package', 'lucide:zap', 'lucide:sliders'][i]} class="size-5" />
              </span>
            </div>
            <h2 data-animate class="mb-3 text-2xl font-bold tracking-tight sm:text-3xl" style="transition-delay:80ms">{f.title}</h2>
            <p data-animate class="mb-5 text-sm leading-relaxed text-muted-foreground sm:text-base" style="transition-delay:160ms">{f.desc}</p>
            <div data-animate class="flex flex-wrap gap-2" style="transition-delay:240ms">
              {features[i].tags.map(tag => (
                <span class="rounded-full border border-border bg-background px-2.5 py-1 text-[11px] text-muted-foreground">{tag}</span>
              ))}
            </div>
          </div>
          <div class={`w-full sm:w-1/2 ${f.reversed ? 'sm:order-1' : ''}`} data-animate style="transition-delay:380ms">
            <div class="relative">
              <div class="absolute -inset-1 rounded-2xl bg-gradient-to-br from-primary/10 to-transparent opacity-60 blur-sm" />
              <img src={f.img} alt={f.title} class="relative w-full rounded-xl border border-border/40 shadow-2xl" loading="lazy" />
            </div>
          </div>
        </div>
        {i < features.length - 1 && <div class="mx-auto h-px max-w-5xl bg-gradient-to-r from-transparent via-border/50 to-transparent" />}
      </div>
    ))}
  </section>

  <!-- Partners / Integration -->
  <section class="border-t border-border/40">
    <div class="mx-auto max-w-5xl px-4 py-16 text-center sm:py-24" data-animate>
      <h2 class="mb-3 text-lg font-semibold sm:text-xl">集成支持</h2>
      <p class="mb-10 text-sm text-muted-foreground">与主流 Minecraft 资源平台深度集成</p>
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
        {partners.map(p => (
          <img src={p.img} alt={p.name} class="h-8 w-auto opacity-50 grayscale transition-all hover:opacity-90 hover:grayscale-0 sm:h-10" loading="lazy" />
        ))}
      </div>
    </div>
  </section>
</Base>

<!-- Download Modal -->
<div id="dl-overlay" class="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto px-4 pt-[12vh] opacity-0 pointer-events-none transition-opacity duration-300">
  <div class="fixed inset-0 bg-black/60 backdrop-blur-xs" id="dl-backdrop"></div>
  <div id="dl-dialog" class="relative w-full max-w-sm rounded-2xl border border-border bg-background p-6 shadow-2xl scale-95 transition-all duration-300">
    <button id="dl-close" class="absolute right-4 top-4 cursor-pointer text-muted-foreground hover:text-foreground transition-colors">
      <Icon name="lucide:x" class="size-5" />
    </button>

    <h3 class="mb-5 text-lg font-semibold">选择平台</h3>

    <div class="flex gap-2 mb-5" id="dl-plats">
      <button data-plat="windows" class="dl-plat flex flex-1 cursor-pointer flex-col items-center gap-2 rounded-xl border-2 border-border px-3 py-4 text-sm font-medium transition-all hover:border-primary/40 active:scale-[0.97]">
        <Icon name="fa6-brands:windows" class="size-6 text-muted-foreground" />Windows
      </button>
      <button data-plat="macos" class="dl-plat flex flex-1 cursor-pointer flex-col items-center gap-2 rounded-xl border-2 border-border px-3 py-4 text-sm font-medium transition-all hover:border-primary/40 active:scale-[0.97]">
        <Icon name="fa6-brands:apple" class="size-6 text-muted-foreground" />macOS
      </button>
      <button data-plat="linux" class="dl-plat flex flex-1 cursor-pointer flex-col items-center gap-2 rounded-xl border-2 border-border px-3 py-4 text-sm font-medium transition-all hover:border-primary/40 active:scale-[0.97]">
        <Icon name="lucide:terminal" class="size-6 text-muted-foreground" />Linux
      </button>
    </div>

    <div id="dl-arch-section" class="mb-5 opacity-0 translate-y-2 transition-all duration-500 ease-out pointer-events-none">
      <p class="mb-2 text-xs text-muted-foreground">选择架构</p>
      <div class="flex gap-2" id="dl-archs"></div>
    </div>

    <div id="dl-type-section" class="mb-5 opacity-0 translate-y-2 transition-all duration-500 ease-out pointer-events-none">
      <p class="mb-2 text-xs text-muted-foreground">选择安装包类型</p>
      <div class="flex gap-2" id="dl-types"></div>
    </div>

    <!-- Download source -->
    <div id="dl-source-section" class="mb-5">
      <p class="mb-2 text-xs text-muted-foreground">下载源</p>
      <div class="flex gap-2" id="dl-sources"></div>
    </div>

    <div id="dl-link-section" class="opacity-0 translate-y-2 transition-all duration-500 ease-out pointer-events-none">
      <a id="dl-link" href="#" target="_blank" class="hidden inline-flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-primary text-sm font-medium text-primary-foreground shadow-lg shadow-primary/20 transition-all hover:bg-primary/90">
        <Icon name="lucide:download" class="size-4" />下载
      </a>
    </div>

    <div id="dl-thanks" class="hidden flex-col items-center py-4 text-center">
      <div class="mb-3 flex size-14 items-center justify-center rounded-full bg-green-500/10">
        <Icon name="lucide:check" class="size-7 text-green-500" />
      </div>
      <p class="mb-1 text-base font-semibold">下载已开始</p>
      <p class="mb-1 text-xs text-muted-foreground">如果下载未自动开始，<a id="dl-retry" href="#" class="text-primary underline underline-offset-2">点击此处重试</a></p>
      <p class="mb-5 text-xs text-muted-foreground">下载完成后，打开安装程序即可开始使用。</p>
      <div class="flex w-full gap-2">
        <a href="/docs/install" class="flex flex-1 items-center justify-center gap-1.5 rounded-xl border border-border bg-background px-4 py-2.5 text-sm font-medium transition-colors hover:bg-accent">
          <Icon name="lucide:book-open" class="size-4" />安装指南
        </a>
        <button id="dl-thanks-close" class="flex flex-1 cursor-pointer items-center justify-center gap-1.5 rounded-xl bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
          知道了
        </button>
      </div>
    </div>
  </div>
</div>

<script data-astro-rerun define:vars={{ stableTag, preTag, stableAssets, preAssets }}>
(function () {
  function matchAsset(assets, plat, arch, pkgType) {
    var candidates = assets.filter(function (a) {
      if (a.name.endsWith('.sig') || a.name.endsWith('.json')) return false
      if (a.name.includes('update-fragment') || a.name === 'latest.json' || a.name === 'beta.json') return false
      if (a.name === 'Qomicex.Launcher.exe') return false
      if (plat === 'windows') {
        if (a.platform !== 'windows') return false
        if (arch === 'ARM64') return /arm|aarch64/i.test(a.name)
        return /x64/i.test(a.name) && !/arm|aarch64/i.test(a.name)
      }
      if (plat === 'macos') {
        if (arch === 'Apple Silicon (ARM64)' && a.platform !== 'macos-arm') return false
        if (arch === 'Intel (x64)' && a.platform !== 'macos-intel') return false
        if (pkgType === 'DMG' && !a.name.endsWith('.dmg')) return false
        if (pkgType === 'TAR.GZ' && !a.name.endsWith('.tar.gz')) return false
        return true
      }
      if (plat === 'linux') {
        if (a.platform !== 'linux') return false
        if (pkgType === 'AppImage' && !a.name.endsWith('.AppImage')) return false
        if (pkgType === 'DEB' && !a.name.endsWith('.deb')) return false
        if (pkgType === 'RPM' && !a.name.endsWith('.rpm')) return false
        if (arch === 'ARM64') return /arm|aarch64/i.test(a.name)
        return /x64|x86_64|amd64/i.test(a.name)
      }
      return false
    })
    return candidates[0] || null
  }

  function extLabel(name) {
    var m = name.match(/\.(exe|msi|dmg|AppImage|tar\.gz)$/)
    return m ? m[1] : ''
  }

  var PLATFORMS = {
    windows: { archLabels: ['x64', 'ARM64'], typeLabels: ['EXE'] },
    macos: { archLabels: ['Intel (x64)', 'Apple Silicon (ARM64)'], typeLabels: ['DMG', 'TAR.GZ'] },
    linux: { archLabels: ['x64', 'ARM64'], typeLabels: ['AppImage', 'DEB', 'RPM'] },
  }

  function detect() {
    var ua = navigator.userAgent
    var plat = 'windows'
    if (/mac/i.test(ua) && !/windows/i.test(ua)) plat = 'macos'
    else if (/linux/i.test(ua)) plat = 'linux'
    var arch
    if (plat === 'macos') {
      arch = (/arm|aarch64/i.test(ua)) ? 'Apple Silicon (ARM64)' : 'Intel (x64)'
    } else {
      arch = (/arm|aarch64/i.test(ua)) ? 'ARM64' : 'x64'
    }
    return { plat: plat, arch: arch }
  }

  var sources = [
    { label: '代理下载 (推荐)', id: 'proxy' },
    { label: '镜像源', id: 'mirror' },
    { label: 'GitHub 直连', id: 'direct' },
  ]

  // lazily re-acquired state
  var $ = {}
  function acquire() {
    $.isPre = false
    $.currentSourceIdx = 0
    $.closeTimer = null
    $.currentType = ''
    var d = detect()
    $.currentPlat = d.plat
    $.currentArch = d.arch
    $.btn = document.getElementById('dl-btn')
    $.overlay = document.getElementById('dl-overlay')
    $.backdrop = document.getElementById('dl-backdrop')
    $.dialog = document.getElementById('dl-dialog')
    $.closeBtn = document.getElementById('dl-close')
    $.archSection = document.getElementById('dl-arch-section')
    $.archContainer = document.getElementById('dl-archs')
    $.typeSection = document.getElementById('dl-type-section')
    $.typeContainer = document.getElementById('dl-types')
    $.sourceSection = document.getElementById('dl-source-section')
    $.sourceContainer = document.getElementById('dl-sources')
    $.linkSection = document.getElementById('dl-link-section')
    $.dlPlats = document.getElementById('dl-plats')
    $.link = document.getElementById('dl-link')
    $.thanks = document.getElementById('dl-thanks')
    $.thanksClose = document.getElementById('dl-thanks-close')
    $.retry = document.getElementById('dl-retry')
    $.preBtn = document.getElementById('dl-pre-btn')
  }

  function getAssets() { return $.isPre ? preAssets : stableAssets }
  function getTag() { return $.isPre ? preTag : stableTag }
  function getTypeLabels() { var c = PLATFORMS[$.currentPlat]; return c ? c.typeLabels : [] }

  function initPlatformType() {
    var labels = getTypeLabels()
    if (labels.length > 1) {
      renderTypes(labels, labels[0])
      $.typeSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
    } else {
      $.currentType = labels[0] || ''
      $.typeSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    }
  }

  function renderTypes(typeLabels, selected) {
    $.typeContainer.innerHTML = ''
    typeLabels.forEach(function (label) {
      var pill = document.createElement('button')
      pill.className = 'dl-type cursor-pointer rounded-lg border px-3.5 py-2 text-xs font-medium transition-all active:scale-[0.97] ' +
        (label === selected ? 'border-primary/40 bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:text-foreground')
      pill.textContent = label
      pill.setAttribute('data-type', label)
      pill.addEventListener('click', function () { selectType(label) })
      $.typeContainer.appendChild(pill)
    })
    $.currentType = selected
  }

  function selectType(label) {
    $.currentType = label
    document.querySelectorAll('.dl-type').forEach(function (p) {
      p.className = 'dl-type cursor-pointer rounded-lg border px-3.5 py-2 text-xs font-medium transition-all active:scale-[0.97] ' +
        (p.getAttribute('data-type') === label ? 'border-primary/40 bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:text-foreground')
    })
    updateLink()
  }

  function renderSources(selectedIdx) {
    $.sourceContainer.innerHTML = ''
    sources.forEach(function (s, i) {
      var btn = document.createElement('button')
      btn.className = 'dl-source cursor-pointer rounded-lg border px-3 py-1.5 text-xs font-medium transition-all active:scale-[0.97] ' +
        (i === selectedIdx ? 'border-primary/40 bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:text-foreground')
      btn.textContent = s.label
      btn.setAttribute('data-src', i)
      btn.addEventListener('click', function () { selectSource(i) })
      $.sourceContainer.appendChild(btn)
    })
  }

  function selectSource(idx) {
    $.currentSourceIdx = idx
    document.querySelectorAll('.dl-source').forEach(function (b) {
      var i = parseInt(b.getAttribute('data-src'))
      b.className = 'dl-source cursor-pointer rounded-lg border px-3 py-1.5 text-xs font-medium transition-all active:scale-[0.97] ' +
        (i === idx ? 'border-primary/40 bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:text-foreground')
    })
    updateLink()
  }

  function openModal(isPreMode) {
    if ($.closeTimer) { clearTimeout($.closeTimer); $.closeTimer = null }
    if (isPreMode === undefined) isPreMode = false
    $.isPre = isPreMode
    $.thanks.classList.add('hidden')
    $.thanks.classList.remove('flex')
    $.dlPlats.style.display = ''
    $.closeBtn.style.display = ''
    $.sourceSection.style.display = ''
    $.archSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.typeSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.linkSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.overlay.classList.remove('opacity-0', 'pointer-events-none')
    setTimeout(function () { $.dialog.classList.remove('scale-95') }, 30)
    renderSourceList()
    highlightPlat($.currentPlat)
    var platConfig = PLATFORMS[$.currentPlat]
    if (platConfig) {
      renderArchs(platConfig.archLabels, $.currentArch)
      initPlatformType()
      showArchTypeAndLink()
    }
  }

  function renderSourceList() { renderSources($.currentSourceIdx) }

  function closeModal() {
    if ($.closeTimer) { clearTimeout($.closeTimer); $.closeTimer = null }
    $.dialog.classList.add('scale-95')
    $.thanks.classList.add('hidden')
    $.thanks.classList.remove('flex')
    $.dlPlats.style.display = ''
    $.closeBtn.style.display = ''
    $.sourceSection.style.display = ''
    hideArchTypeAndLink()
    $.closeTimer = setTimeout(function () { $.overlay.classList.add('opacity-0', 'pointer-events-none') }, 200)
  }

  function hideArchTypeAndLink() {
    $.archSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.typeSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.linkSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.link.classList.add('hidden')
  }

  function showThanks() {
    $.dlPlats.style.display = 'none'
    $.closeBtn.style.display = 'none'
    $.sourceSection.style.display = 'none'
    $.archSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.typeSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.linkSection.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none')
    $.link.classList.add('hidden')
    $.thanks.classList.remove('hidden')
    $.thanks.classList.add('flex')
    $.retry.href = $.link.href
  }

  function highlightPlat(id) {
    document.querySelectorAll('.dl-plat').forEach(function (b) {
      var isActive = b.getAttribute('data-plat') === id
      b.className = 'dl-plat flex flex-1 cursor-pointer flex-col items-center gap-2 rounded-xl border-2 px-3 py-4 text-sm font-medium transition-all active:scale-[0.97] ' +
        (isActive ? 'border-primary bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:border-primary/40')
    })
  }

  function renderArchs(archList, selected) {
    $.archContainer.innerHTML = ''
    archList.forEach(function (label) {
      var pill = document.createElement('button')
      pill.className = 'dl-arch cursor-pointer rounded-lg border px-3.5 py-2 text-xs font-medium transition-all active:scale-[0.97] ' +
        (label === selected ? 'border-primary/40 bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:text-foreground')
      pill.textContent = label
      pill.setAttribute('data-arch', label)
      pill.addEventListener('click', function () { selectArch(label) })
      $.archContainer.appendChild(pill)
    })
    $.currentArch = selected
  }

  function selectArch(label) {
    $.currentArch = label
    document.querySelectorAll('.dl-arch').forEach(function (p) {
      p.className = 'dl-arch cursor-pointer rounded-lg border px-3.5 py-2 text-xs font-medium transition-all active:scale-[0.97] ' +
        (p.getAttribute('data-arch') === label ? 'border-primary/40 bg-primary/5 text-primary' : 'border-border text-muted-foreground hover:text-foreground')
    })
    updateLink()
  }

  function showArchTypeAndLink() {
    $.archSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
    setTimeout(function () {
      var labels = getTypeLabels()
      if (labels.length > 1) {
        $.typeSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
      }
      $.linkSection.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none')
      updateLink()
    }, 250)
  }

  function assetUrl(match) {
    var s = sources[$.currentSourceIdx]
    if (s.id === 'direct') return match.url
    if (s.id === 'mirror') return 'https://gh.lenmei233.top/' + match.url
    return 'https://gh-proxy.com/' + match.url
  }

  function updateLink() {
    var assets = getAssets()
    var match = matchAsset(assets, $.currentPlat, $.currentArch, $.currentType)
    if (match) {
      $.link.href = assetUrl(match)
      $.link.textContent = '下载 ' + $.currentArch + ' (' + $.currentType + ')'
      $.link.classList.remove('hidden')
    } else {
      $.link.href = 'https://github.com/Qomicex-Public/Qomicex.Tauri/releases/' + (getTag() || 'latest')
      $.link.textContent = '下载 ' + $.currentType
      $.link.classList.remove('hidden')
    }
  }

  function switchPlat(id) {
    if (id === $.currentPlat) return
    $.currentPlat = id
    highlightPlat(id)
    var platConfig = PLATFORMS[id]
    if (!platConfig) return
    var ua = navigator.userAgent
    var arch
    if (id === 'macos') {
      arch = (/arm|aarch64/i.test(ua)) ? 'Apple Silicon (ARM64)' : 'Intel (x64)'
    } else {
      arch = (/arm|aarch64/i.test(ua)) ? 'ARM64' : 'x64'
    }
    hideArchTypeAndLink()
    setTimeout(function () {
      renderArchs(platConfig.archLabels, arch)
      initPlatformType()
      showArchTypeAndLink()
      $.currentArch = arch
    }, 300)
  }

  // --- event delegation (registered once per page lifecycle) ---
  if (!window._downloadInit) {
    window._downloadInit = true
    document.addEventListener('click', function (e) {
      var el = e.target.closest('#dl-btn, .dl-plat, .dl-arch, .dl-type, .dl-source, #dl-link, #dl-thanks-close, #dl-close, #dl-backdrop, #dl-pre-btn')
      if (!el) return
      if (el.id === 'dl-btn') { openModal(false); return }
      if (el.id === 'dl-pre-btn') { e.preventDefault(); openModal(true); return }
      if (el.classList.contains('dl-plat')) { switchPlat(el.getAttribute('data-plat')); return }
      if (el.classList.contains('dl-arch')) { selectArch(el.getAttribute('data-arch')); return }
      if (el.classList.contains('dl-type')) { selectType(el.getAttribute('data-type')); return }
      if (el.classList.contains('dl-source')) { selectSource(parseInt(el.getAttribute('data-src'))); return }
      if (el.id === 'dl-link') { e.preventDefault(); window.open($.link.href, '_blank'); showThanks(); return }
      if (el.id === 'dl-thanks-close' || el.id === 'dl-close') { closeModal(); return }
      if (el.id === 'dl-backdrop') { closeModal(); return }
    })
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal() })
  }

  acquire()
  renderSources($.currentSourceIdx)
  document.addEventListener('astro:page-load', acquire)

  // --- carousel ---
  var lang = document.documentElement.lang.startsWith('en') ? 'en' : 'zh'
  var carouselWords = {
    zh: ['多实例管理', '快捷的模组安装', '账户管理', '多人联机', '个性化主题设置'],
    en: ['Multi-instance', 'Quick Mod Install', 'Account Management', 'Multiplayer', 'Custom Themes'],
  }
  var features = carouselWords[lang]
  var carouselIdx = 0
  var carouselTimer = null

  function showWord(text, instant) {
    var el = document.getElementById('carousel-word')
    if (!el) return
    el.textContent = ''
    var chars = text.split('')
    chars.forEach(function (ch, i) {
      var span = document.createElement('span')
      span.textContent = ch
      if (!instant) {
        span.className = 'char-bounce'
        span.style.animationDelay = (i * 0.045).toFixed(3) + 's'
      }
      el.appendChild(span)
    })
  }

  function nextWord() {
    carouselIdx = (carouselIdx + 1) % features.length
    showWord(features[carouselIdx])
  }

  function initCarousel() {
    if (carouselTimer) clearInterval(carouselTimer)
    showWord(features[0], true)
    carouselTimer = setInterval(nextWord, 3000)
  }

  initCarousel()
  document.addEventListener('astro:page-load', function () {
    if (carouselTimer) clearInterval(carouselTimer)
    initCarousel()
  })
})()
</script>
