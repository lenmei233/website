        <li class="mb-1.5"><a href="#chap7" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第七章</span>知识产权</a></li>
        <li class="mb-1.5"><a href="#chap8" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第八章</span>隐私说明</a></li>
        <li class="mb-1.5"><a href="#chap9" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第九章</span>免责声明</a></li>
        <li class="mb-1.5"><a href="#chap10" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第十章</span>责任限制</a></li>
        <li class="mb-1.5"><a href="#chap11" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第十一章</span>协议终止</a></li>
        <li class="mb-1.5"><a href="#chap12" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第十二章</span>法律管辖与争议解决</a></li>
        <li class="mb-1.5"><a href="#chap13" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第十三章</span>协议变更</a></li>
        <li class="mb-1.5"><a href="#chap14" class="text-muted-foreground no-underline hover:text-primary hover:underline"><span class="text-primary font-semibold mr-1">第十四章</span>联系方式</a></li>
