---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- ─── Hero ─── -->
  <section class="relative overflow-hidden border-b border-border">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,hsl(var(--primary)/0.08)_0%,transparent_60%)]" />
    <div class="mx-auto flex max-w-4xl flex-col items-center px-4 py-20 text-center sm:py-28">
      <img src="/high_logo.svg" alt="Qomicex Launcher" class="mb-8 w-full max-w-md" />

      <p class="mb-2 text-lg text-muted-foreground">
        一个现代化的 Minecraft 启动器
      </p>
      <p class="mb-10 max-w-md text-sm text-muted-foreground">
        支持多版本管理、模组加载器兼容、账户管理等多功能于一体。
      </p>

      <div class="flex flex-wrap justify-center gap-3">
        <a href="/download" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-all hover:bg-primary/90 hover:shadow-lg">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
          下载 Qomicex
        </a>
        <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
      </div>

      <div class="mt-8 flex items-center gap-4 text-xs text-muted-foreground">
        <span class="flex items-center gap-1.5">
          <svg class="size-3.5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2" /><line x1="8" y1="4" x2="8" y2="20" /><line x1="16" y1="4" x2="16" y2="20" /></svg>
          Windows
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="size-3.5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20l16-4V4L4 8z" /><path d="M4 8v12" /><path d="M20 4v12" /></svg>
          macOS
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="size-3.5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4" /><path d="M12 2v4" /><path d="M12 18v4" /><path d="M2 12h4" /><path d="M18 12h4" /></svg>
          Linux
        </span>
      </div>
    </div>
  </section>

  <!-- ─── 功能亮点 ─── -->
  <section class="mx-auto max-w-5xl px-4 py-20">
    <div class="mb-12 text-center">
      <h2 class="text-2xl font-bold">核心功能</h2>
      <p class="mt-2 text-sm text-muted-foreground">开箱即用，一切为你所需</p>
    </div>
    <div class="anim-stagger grid gap-4 sm:grid-cols-3">
      {[
        {
          icon: 'M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7z M9 12h6 M12 9v6',
          title: '多版本管理',
          desc: '同时安装和管理多个 Minecraft 版本，版本隔离互不干扰',
        },
        {
          icon: 'M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5 M2 12l10 5 10-5',
          title: '模组加载器',
          desc: '支持 Forge、Fabric、Quilt、NeoForge、OptiFine 等主流加载器',
        },
        {
          icon: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
          title: '账户管理',
          desc: '支持 Microsoft、离线账户、外置登录 (Authlib-Injector)',
        },
      ].map(f => (
        <div class="rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:shadow-[0_0_20px_-8px_hsl(var(--primary)/0.3)]">
          <div class="mb-4 flex size-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {f.icon.split(' ').map(d => <path d={d} />)}
            </svg>
          </div>
          <h3 class="mb-2 font-semibold">{f.title}</h3>
          <p class="text-sm text-muted-foreground">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── "不止于启动" 特色区 ─── -->
  <section class="border-y border-border bg-card/50">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <div class="mb-12 text-center">
        <h2 class="text-2xl font-bold">不止于启动</h2>
        <p class="mt-2 text-sm text-muted-foreground">更多功能，让游戏体验更完整</p>
      </div>
      <div class="anim-stagger grid gap-4 sm:grid-cols-2">
        {[
          {
            icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M12 12l-2-2 M12 12l-2 2 M12 12l2 2 M12 12l2-2',
            title: '资源中心',
            desc: '从 Modrinth、CurseForge、Mcmod 等平台一站式搜索和安装模组、资源包、光影包。',
          },
          {
            icon: 'M5 12h14 M12 5l7 7-7 7',
            title: '联机功能',
            desc: '基于 EasyTier 的内网穿透联机，无需公网 IP 即可与好友畅玩。',
          },
          {
            icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
            title: '实时日志',
            desc: '强大的日志窗口和错误分析器，精确定位游戏问题，启动过程全程可见。',
          },
          {
            icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
            title: '安全透明',
            desc: '完全开源 (GPL-3.0)，不收集任何用户数据。所有配置仅存储在本地。',
          },
        ].map(f => (
          <div class="flex gap-4 rounded-xl border border-border bg-background p-5 transition-all hover:border-primary/30">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
              <svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {f.icon.split(' ').map(d => <path d={d} />)}
              </svg>
            </div>
            <div>
              <h3 class="mb-1 font-semibold">{f.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 下载 ─── -->
  <section class="mx-auto max-w-4xl px-4 py-20">
    <div class="mb-12 text-center">
      <h2 class="text-2xl font-bold">下载 Qomicex</h2>
      <p class="mt-2 text-sm text-muted-foreground">选择你的平台，即刻开始</p>
    </div>
    <div class="anim-stagger grid gap-4 sm:grid-cols-3">
      {[
        { platform: 'Windows', icon: 'M4 4h7v7H4z M13 4h7v7h-7z M4 13h7v7H4z M13 13h7v7h-7z', desc: 'Windows 10/11 64位', note: '.msi' },
        { platform: 'macOS', icon: 'M4 4h16v12c0 1.1-.9 2-2 2H6c-1.1 0-2-.9-2-2V4z M8 2v2 M16 2v2', desc: 'macOS 11+', note: '.dmg' },
        { platform: 'Linux', icon: 'M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5 M2 12l10 5 10-5', desc: 'Linux x86_64 / ARM64', note: '.AppImage / .deb' },
      ].map(p => (
        <a
          href="https://github.com/Qomicex-Public/Qomicex.Tauri/releases/latest"
          target="_blank"
          class="group rounded-xl border border-border bg-card p-6 text-center transition-all hover:border-primary/40 hover:shadow-[0_0_24px_-8px_hsl(var(--primary)/0.25)]"
        >
          <div class="mx-auto mb-4 flex size-12 items-center justify-center rounded-xl bg-primary/10 transition-colors group-hover:bg-primary/20">
            <svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {p.icon.split(' ').map(d => <path d={d} />)}
            </svg>
          </div>
          <h3 class="mb-1 font-semibold">{p.platform}</h3>
          <p class="mb-1 text-xs text-muted-foreground">{p.desc}</p>
          <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">{p.note}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ─── 社区 ─── -->
  <section class="border-t border-border bg-card/50">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center">
      <h2 class="mb-4 text-2xl font-bold">加入社区</h2>
      <p class="mb-8 text-sm text-muted-foreground">Qomicex 是完全开源的项目，欢迎参与贡献</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="https://github.com/Qomicex-Public" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://qm.qq.com/q/rKiwzrkg8w" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12c0 5.5 4.5 10 10 10s10-4.5 10-10c0-5.5-4.5-10-10-10z" /><path d="M8 14s1.5 2 4 2 4-2 4-2" /><line x1="9" y1="9" x2="9.01" y2="9" /><line x1="15" y1="9" x2="15.01" y2="9" /></svg>
          QQ 群
        </a>
        <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow transition-all hover:bg-primary/90 hover:shadow-lg">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8" /><line x1="4" y1="20" x2="21" y2="3" /><polyline points="21 16 21 21 16 21" /><line x1="15" y1="15" x2="21" y2="21" /><line x1="4" y1="4" x2="9" y2="9" /></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</Base>
