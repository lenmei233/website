---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
---

<Base>
  <!-- ─── Hero ─── -->
  <section class="relative overflow-hidden border-b border-border">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,hsl(var(--primary)/0.08)_0%,transparent_60%)]" />
    <div class="mx-auto flex max-w-4xl flex-col items-center px-4 py-20 text-center sm:py-28">
      <img src="/high_logo.svg" alt="Qomicex Launcher" class="mb-8 w-full max-w-md" />

      <p class="mb-2 text-lg text-muted-foreground">
        一个现代化的 Minecraft 启动器
      </p>
      <p class="mb-10 max-w-md text-sm text-muted-foreground">
        拥有完善的多实例管理、快捷的模组安装、账户管理、多人联机、个性化主题设置等功能。
      </p>

      <div class="flex flex-wrap justify-center gap-3">
        <a href="/download" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-all hover:bg-primary/90 hover:shadow-lg">
          <Icon name="lucide:download" class="size-4" />
          下载 Qomicex
        </a>
        <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
          <Icon name="fa6-brands:github" class="size-4" />
          GitHub
        </a>
      </div>

      <div class="mt-8 flex items-center gap-4 text-xs text-muted-foreground">
        <span class="flex items-center gap-1.5">
          <Icon name="fa6-brands:windows" class="size-3.5 text-primary" />
          Windows
        </span>
        <span class="flex items-center gap-1.5">
          <Icon name="fa6-brands:apple" class="size-3.5 text-primary" />
          macOS
        </span>
        <span class="flex items-center gap-1.5">
          <Icon name="lucide:terminal" class="size-3.5 text-primary" />
          Linux
        </span>
      </div>
    </div>
  </section>

  <!-- ─── 功能亮点 ─── -->
  <section data-animate class="mx-auto max-w-5xl px-4 py-20">
    <div class="mb-12 text-center">
      <h2 class="text-2xl font-bold">核心功能</h2>
      <p class="mt-2 text-sm text-muted-foreground">开箱即用，一切为你所需</p>
    </div>
    <div class="anim-stagger grid gap-4 sm:grid-cols-3">
      {[
        { icon: 'lucide:layers', title: '多版本管理', desc: '同时安装和管理多个 Minecraft 版本，版本隔离互不干扰' },
        { icon: 'lucide:puzzle', title: '模组加载器', desc: '支持 Forge、Fabric、Quilt、NeoForge、OptiFine 等主流加载器' },
        { icon: 'lucide:users', title: '账户管理', desc: '支持 Microsoft、离线账户、外置登录 (Authlib-Injector)' },
      ].map(f => (
        <div class="rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:shadow-[0_0_20px_-8px_hsl(var(--primary)/0.3)]">
          <div class="mb-4 flex size-10 items-center justify-center rounded-lg bg-primary/10">
            <Icon name={f.icon} class="size-5 text-primary" />
          </div>
          <h3 class="mb-2 font-semibold">{f.title}</h3>
          <p class="text-sm text-muted-foreground">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── "不止于启动" 特色区 ─── -->
  <section data-animate class="border-y border-border bg-card/50">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <div class="mb-12 text-center">
        <h2 class="text-2xl font-bold">不止于启动</h2>
        <p class="mt-2 text-sm text-muted-foreground">更多功能，让游戏体验更完整</p>
      </div>
      <div class="anim-stagger grid gap-4 sm:grid-cols-2">
        {[
          { icon: 'lucide:package', title: '资源中心', desc: '从 Modrinth、CurseForge、Mcmod 等平台一站式搜索和安装模组、资源包、光影包。' },
          { icon: 'lucide:globe', title: '联机功能', desc: '基于 EasyTier 的内网穿透联机，无需公网 IP 即可与好友畅玩。' },
          { icon: 'lucide:scroll-text', title: '实时日志', desc: '强大的日志窗口和错误分析器，精确定位游戏问题，启动过程全程可见。' },
          { icon: 'lucide:shield-check', title: '安全透明', desc: '完全开源 (GPL-3.0)，不收集任何用户数据。所有配置仅存储在本地。' },
        ].map(f => (
          <div class="flex gap-4 rounded-xl border border-border bg-background p-5 transition-all hover:border-primary/30">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
              <Icon name={f.icon} class="size-5 text-primary" />
            </div>
            <div>
              <h3 class="mb-1 font-semibold">{f.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 下载 ─── -->
  <section data-animate class="mx-auto max-w-4xl px-4 py-20">
    <div class="mb-12 text-center">
      <h2 class="text-2xl font-bold">下载 Qomicex</h2>
      <p class="mt-2 text-sm text-muted-foreground">选择你的平台，即刻开始</p>
    </div>
    <div class="anim-stagger grid gap-4 sm:grid-cols-3">
      {[
        { icon: 'fa6-brands:windows', platform: 'Windows', desc: 'Windows 10/11 64位', note: '.msi' },
        { icon: 'fa6-brands:apple', platform: 'macOS', desc: 'macOS 11+', note: '.dmg' },
        { icon: 'lucide:terminal', platform: 'Linux', desc: 'Linux x86_64 / ARM64', note: '.AppImage / .deb' },
      ].map(p => (
        <a
          href="https://github.com/Qomicex-Public/Qomicex.Tauri/releases/latest"
          target="_blank"
          class="group rounded-xl border border-border bg-card p-6 text-center transition-all hover:border-primary/40 hover:shadow-[0_0_24px_-8px_hsl(var(--primary)/0.25)]"
        >
          <div class="mx-auto mb-4 flex size-12 items-center justify-center rounded-xl bg-primary/10 transition-colors group-hover:bg-primary/20">
            <Icon name={p.icon} class="size-6 text-primary" />
          </div>
          <h3 class="mb-1 font-semibold">{p.platform}</h3>
          <p class="mb-1 text-xs text-muted-foreground">{p.desc}</p>
          <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">{p.note}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ─── 社区 ─── -->
  <section data-animate class="border-t border-border bg-card/50">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center">
      <h2 class="mb-4 text-2xl font-bold">加入社区</h2>
      <p class="mb-8 text-sm text-muted-foreground">Qomicex 是完全开源的项目，欢迎参与贡献</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="https://github.com/Qomicex-Public" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
          <Icon name="fa6-brands:github" class="size-4" />
          GitHub
        </a>
        <a href="https://qm.qq.com/q/rKiwzrkg8w" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
          <Icon name="lucide:message-circle" class="size-4" />
          QQ 群
        </a>
        <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow transition-all hover:bg-primary/90 hover:shadow-lg">
          <Icon name="lucide:star" class="size-4" />
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</Base>
