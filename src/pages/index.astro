---
import Base from '../layouts/Base.astro';
---

<Base>
  <section class="mx-auto flex min-h-[70vh] max-w-4xl flex-col items-center justify-center px-4 text-center">
    <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
      现代化的 <span class="text-primary">Minecraft</span> 启动器
    </h1>
    <p class="mb-8 max-w-lg text-lg text-muted-foreground">
      支持多版本管理、模组加载器兼容、账户管理等多功能于一体的 Minecraft 启动器。
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/download" class="inline-flex h-10 items-center justify-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
        下载 Qomicex
      </a>
      <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-10 items-center justify-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
        GitHub
      </a>
    </div>
    <div class="mt-16 grid gap-4 sm:grid-cols-3">
      {[
        { title: '多版本管理', desc: '同时安装和管理多个 Minecraft 版本，互不干扰' },
        { title: '模组加载器', desc: '支持 Forge、Fabric、Quilt、NeoForge 等主流加载器' },
        { title: '账户管理', desc: '支持 Microsoft 账户、离线账户、外置登录等多种方式' },
      ].map(f => (
        <div class="rounded-xl border border-border bg-card p-5 text-left">
          <h3 class="mb-2 font-semibold text-primary">{f.title}</h3>
          <p class="text-sm text-muted-foreground">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
