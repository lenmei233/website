---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { getReleases, MIRRORS } from '../lib/releases.ts';

const releases = await getReleases()
const stable = releases.find(r => !r.prerelease)
const pre = releases.find(r => r.prerelease)

const MIRROR_URL = MIRRORS.find(m => m.label === 'gh.lenmei233.top')?.url ?? ''

const ASH_GROUPS = [
  {
    id: 'windows', icon: 'fa6-brands:windows', label: 'Windows',
    archs: [
      { label: 'x64', file: (v: string) => `Qomicex_${v}_x64-setup.msi` },
      { label: 'ARM64', file: (v: string) => `Qomicex_${v}_arm64-setup.msi` },
    ],
  },
  {
    id: 'macos', icon: 'fa6-brands:apple', label: 'macOS',
    archs: [
      { label: 'Intel (x64)', file: (v: string) => `Qomicex_${v}_x64.dmg` },
      { label: 'Apple Silicon (ARM64)', file: (v: string) => `Qomicex_${v}_aarch64.dmg` },
    ],
  },
  {
    id: 'linux', icon: 'lucide:terminal', label: 'Linux',
    archs: [
      { label: 'x64', file: (v: string) => `Qomicex_${v}_amd64.AppImage` },
      { label: 'ARM64', file: (v: string) => `Qomicex_${v}_arm64.AppImage` },
      { label: 'LoongArch64 (实验性)', file: () => '' },
      { label: 'RISC-V 64 (实验性)', file: () => '' },
    ],
  },
]

function ghUrl(ver: string, file: string): string {
  return file ? `https://github.com/Qomicex-Public/Qomicex.Tauri/releases/download/${ver}/${file}` : ''
}
---

<Base title="下载">
  <section class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="mb-1 text-center text-3xl font-bold">下载 Qomicex Launcher</h1>
    <p class="mb-8 text-center text-sm text-muted-foreground">选择你的平台和架构，开始下载。</p>

    <!-- Stable / Pre tabs -->
    <div class="mb-8 flex justify-center gap-1.5 rounded-xl bg-muted p-1">
      <label class="relative cursor-pointer rounded-lg bg-background px-4 py-2 text-sm font-medium text-foreground shadow-sm">
        <input type="radio" name="rel-tab" value="stable" checked class="peer hidden" />
        <span class="flex items-center gap-1.5"><Icon name="lucide:verified" class="size-4" />正式版{stable ? ` ${stable.version}` : ''}</span>
      </label>
      {pre && (
      <label class="relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
        <input type="radio" name="rel-tab" value="pre" class="peer hidden" />
        <span class="flex items-center gap-1.5"><Icon name="lucide:beaker" class="size-4" />测试版 {pre.version}</span>
      </label>
      )}
    </div>

    <!-- Stable content -->
    <div id="rel-stable" class="space-y-6">
      {stable ? (
        <>
          <div class="mb-4 flex justify-center gap-1.5 rounded-xl bg-muted p-1">
            {ASH_GROUPS.map((g, i) => (
              <label class={"relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors " + (i === 0 ? 'bg-background text-foreground shadow-sm' : 'text-muted-foreground hover:text-foreground')}>
                <input type="radio" name="plat-stable" value={g.id} checked={i === 0} class="peer hidden" />
                <span class="flex items-center gap-1.5"><Icon name={g.icon} class="size-4" />{g.label}</span>
              </label>
            ))}
          </div>
          {ASH_GROUPS.map((g, gi) => (
            <div id={"sarchs-" + g.id} class={"space-y-4 " + (gi === 0 ? '' : 'hidden')}>
              <div class="flex flex-wrap justify-center gap-2">
                {g.archs.map((a, ai) => {
                  const fn = a.file(stable.version)
                  const url = ghUrl(stable.tagName, fn)
                  return (
                    <div class={"flex items-center gap-2 rounded-xl border p-3 transition-colors " + (ai === 0 ? 'border-primary/30 bg-primary/5' : 'border-border')}>
                      <label class="flex cursor-pointer items-center gap-2 text-sm">
                        <input type="radio" name={"arch-s-" + g.id} value={a.label} checked={ai === 0} class="size-3.5 accent-primary" />
                        {a.label}
                      </label>
                    </div>
                  )
                })}
              </div>
              <div class="flex flex-wrap justify-center gap-3">
                {(() => {
                  const fn0 = g.archs[0].file(stable.version)
                  const u0 = ghUrl(stable.tagName, fn0)
                  const href = u0 || stable.htmlUrl
                  return (
                    <>
                      <a href={href} target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-all hover:bg-primary/90 hover:shadow-lg" data-line="1">
                        <Icon name="lucide:download" class="size-4" />下载线路 1
                      </a>
                      <a href={MIRROR_URL + href} target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground" data-line="2">
                        <Icon name="lucide:zap" class="size-4" />下载线路 2
                      </a>
                    </>
                  )
                })()}
              </div>
            </div>
          ))}
        </>
      ) : <p class="text-center text-muted-foreground">暂无正式版。</p>}
    </div>

    <!-- Pre content -->
    {pre && (
    <div id="rel-pre" class="hidden space-y-6">
      <div class="flex items-center gap-2 rounded-lg bg-yellow-500/10 px-4 py-3 text-sm text-yellow-700 dark:text-yellow-300">
        <Icon name="lucide:beaker" class="size-4 shrink-0" />测试版包含最新功能但可能不稳定。
      </div>
      <div class="mb-4 flex justify-center gap-1.5 rounded-xl bg-muted p-1">
        {ASH_GROUPS.map((g, i) => (
          <label class={"relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors " + (i === 0 ? 'bg-background text-foreground shadow-sm' : 'text-muted-foreground hover:text-foreground')}>
            <input type="radio" name="plat-pre" value={g.id} checked={i === 0} class="peer hidden" />
            <span class="flex items-center gap-1.5"><Icon name={g.icon} class="size-4" />{g.label}</span>
          </label>
        ))}
      </div>
      {ASH_GROUPS.map((g, gi) => (
        <div id={"parchs-" + g.id} class={"space-y-4 " + (gi === 0 ? '' : 'hidden')}>
          <div class="flex flex-wrap justify-center gap-2">
            {g.archs.map((a, ai) => {
              const fn = a.file(pre.version)
              const url = ghUrl(pre.tagName, fn)
              return (
                <div class={"flex items-center gap-2 rounded-xl border p-3 transition-colors " + (ai === 0 ? 'border-yellow-500/30 bg-yellow-500/5' : 'border-border')}>
                  <label class="flex cursor-pointer items-center gap-2 text-sm">
                    <input type="radio" name={"arch-p-" + g.id} value={a.label} checked={ai === 0} class="size-3.5 accent-yellow-600" />
                    {a.label}
                  </label>
                </div>
              )
            })}
          </div>
          <div class="flex flex-wrap justify-center gap-3">
            {(() => {
              const fn0 = g.archs[0].file(pre.version)
              const u0 = ghUrl(pre.tagName, fn0)
              const href = u0 || pre.htmlUrl
              return (
                <>
                  <a href={href} target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md bg-yellow-600 px-6 text-sm font-medium text-white shadow transition-all hover:bg-yellow-700 hover:shadow-lg">
                    <Icon name="lucide:download" class="size-4" />下载线路 1
                  </a>
                  <a href={MIRROR_URL + href} target="_blank" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-sm transition-all hover:bg-accent hover:text-accent-foreground">
                    <Icon name="lucide:zap" class="size-4" />下载线路 2
                  </a>
                </>
              )
            })()}
          </div>
        </div>
      ))}
    </div>
    )}

    <!-- Platform compat -->
    <div class="mt-10 rounded-xl border border-border bg-card p-5">
      <h3 class="mb-3 text-sm font-semibold">兼容平台</h3>
      <div class="overflow-x-auto text-sm">
        <table class="w-full text-left text-xs">
          <thead>
            <tr class="border-b border-border text-muted-foreground">
              <th class="py-2 pr-3 font-medium">平台</th>
              <th class="py-2 pr-3 font-medium">支持架构</th>
              <th class="py-2 pr-3 font-medium">最低系统版本</th>
              <th class="py-2 pr-3 font-medium">测试状态</th>
              <th class="py-2 font-medium">安装包/方式</th>
            </tr>
          </thead>
          <tbody class="text-muted-foreground">
            <tr class="border-b border-border/50">
              <td class="py-2.5 pr-3 font-medium text-foreground">Windows</td>
              <td class="py-2.5 pr-3">x64, ARM64</td>
              <td class="py-2.5 pr-3">Windows 10 1809+</td>
              <td class="py-2.5 pr-3"><span class="text-green-600 dark:text-green-400">✅ 稳定</span></td>
              <td class="py-2.5">.exe（NSIS 安装器）</td>
            </tr>
            <tr class="border-b border-border/50">
              <td class="py-2.5 pr-3 font-medium text-foreground">macOS</td>
              <td class="py-2.5 pr-3">x64（Intel）<br />ARM64（Apple Silicon）</td>
              <td class="py-2.5 pr-3">macOS 10.15+</td>
              <td class="py-2.5 pr-3"><span class="text-green-600 dark:text-green-400">✅ 稳定</span></td>
              <td class="py-2.5">.dmg / .app</td>
            </tr>
            <tr>
              <td class="py-2.5 pr-3 font-medium text-foreground">Linux</td>
              <td class="py-2.5 pr-3">
                x64, ARM64<br />
                <span class="text-muted-foreground/60">LoongArch64（理论可用但无机器）</span><br />
                <span class="text-muted-foreground/60">RISC-V 64（实验性，推进中）</span>
              </td>
              <td class="py-2.5 pr-3">Ubuntu 20.04+ / Fedora 34+ / glibc 2.28+</td>
              <td class="py-2.5 pr-3"><span class="text-green-600 dark:text-green-400">✅ 稳定</span></td>
              <td class="py-2.5">.deb / .rpm / AppImage</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Base>

<script data-astro-rerun>
  // Platform tabs switching for stable
  document.querySelectorAll('input[name="plat-stable"]').forEach(function (r) {
    r.addEventListener('change', function () {
      document.querySelectorAll('[id^="sarchs-"]').forEach(function (el) { el.classList.add('hidden') })
      var t = document.getElementById('sarchs-' + this.value)
      if (t) t.classList.remove('hidden')
      document.querySelectorAll('input[name="plat-stable"]').forEach(function (rb) {
        rb.parentElement.className = 'relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors text-muted-foreground hover:text-foreground'
      })
      this.parentElement.className = 'relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors bg-background text-foreground shadow-sm'
    })
  })
  // Platform tabs switching for prerelease
  document.querySelectorAll('input[name="plat-pre"]').forEach(function (r) {
    r.addEventListener('change', function () {
      document.querySelectorAll('[id^="parchs-"]').forEach(function (el) { el.classList.add('hidden') })
      var t = document.getElementById('parchs-' + this.value)
      if (t) t.classList.remove('hidden')
      document.querySelectorAll('input[name="plat-pre"]').forEach(function (rb) {
        rb.parentElement.className = 'relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors text-muted-foreground hover:text-foreground'
      })
      this.parentElement.className = 'relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors bg-background text-foreground shadow-sm'
    })
  })
  // Release tab switching
  document.querySelectorAll('input[name="rel-tab"]').forEach(function (r) {
    r.addEventListener('change', function () {
      document.querySelectorAll('[id^="rel-"]').forEach(function (el) { el.classList.add('hidden') })
      var t = document.getElementById('rel-' + this.value)
      if (t) t.classList.remove('hidden')
      document.querySelectorAll('input[name="rel-tab"]').forEach(function (rb) {
        rb.parentElement.className = 'relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors text-muted-foreground hover:text-foreground'
      })
      this.parentElement.className = 'relative cursor-pointer rounded-lg px-4 py-2 text-sm font-medium transition-colors bg-background text-foreground shadow-sm'
    })
  })
</script>
