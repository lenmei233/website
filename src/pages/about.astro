---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { getReleases } from '../lib/releases.ts';

const releases = await getReleases()
const latestStable = releases.find(r => !r.prerelease)
const latestPre = releases.find(r => r.prerelease)

const CONTRIBUTORS = [
  { name: 'lenmei233', role: '项目发起人 / 主要开发者', url: 'https://github.com/lenmei233' },
  { name: 'TheMyceliumOfAntan', role: '项目发起人 / 主要开发者', url: 'https://github.com/TheMyceliumOfAntan' },
]

const SERVICES = [
  { name: 'Modrinth', desc: 'Mod 和资源搜索 API', url: 'https://modrinth.com' },
  { name: 'CurseForge', desc: 'Mod 和资源搜索 API', url: 'https://www.curseforge.com' },
  { name: 'FTB', desc: '整合包 API', url: 'https://www.feed-the-beast.com' },
  { name: 'bangbang93', desc: '提供 BMCLAPI 下载镜像服务', url: 'https://bmclapi2.bangbang93.com' },
  { name: 'mcmod', desc: '中文 Mod 数据库', url: 'https://www.mcmod.cn' },
  { name: 'Minecraft 官网', desc: 'Minecraft 官方网站', url: 'https://www.minecraft.net' },
]

const REFERENCES = [
  { name: 'HMCL', url: 'https://github.com/HMCL-dev/HMCL/tree/main', desc: '版本检测参考' },
  { name: 'ProjBobcat', url: 'https://github.com/Corona-Studio/ProjBobcat', desc: 'ModLoader 安装器参考' },
  { name: 'PCL', url: 'https://github.com/Meloong-Git/PCL', desc: '启动流程参考' },
]
---

<Base title="关于">
  <section data-animate class="mx-auto max-w-3xl px-4 py-16">
    <!-- App Info -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <div class="flex items-center gap-4">
        <img src="/logo.svg" alt="Qomicex Launcher" class="h-14 w-14 rounded-2xl" />
        <div class="min-w-0 flex-1">
          <div class="text-lg font-semibold">Qomicex Launcher</div>
          <div class="text-sm text-muted-foreground">版本 {latestPre ? `${latestPre.version}${latestPre.prerelease ? ' (测试版)' : ''}` : latestStable?.version ?? '...'}</div>
        </div>
        <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-7 items-center gap-1.5 rounded-md px-2.5 text-xs font-medium transition-colors hover:bg-accent hover:text-accent-foreground">
          <Icon name="fa6-brands:github" class="size-3" />查看仓库
        </a>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">一个现代化的 Minecraft 启动器，支持多版本管理、模组加载器兼容、账户管理、内网穿透联机等功能。完全开源，使用 GPL-3.0 许可协议。</p>
    </div>

    <!-- Version Info -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">版本信息</h2>
      <div class="rounded-lg bg-background p-4 text-sm">
        <div class="grid grid-cols-2 gap-3">
          {latestStable && <div><div class="text-xs text-muted-foreground">正式版</div><div class="mt-0.5 font-medium">{latestStable.version}</div></div>}
          {latestPre && <div><div class="text-xs text-muted-foreground">测试版</div><div class="mt-0.5 font-medium">{latestPre.version}</div></div>}
          {!latestStable && !latestPre && <div><div class="text-xs text-muted-foreground">应用版本</div><div class="mt-0.5 font-medium">...</div></div>}
          <div><div class="text-xs text-muted-foreground">许可协议</div><div class="mt-0.5 font-medium"><a href="https://www.gnu.org/licenses/gpl-3.0.en.html" target="_blank" class="text-primary underline underline-offset-2">GPL-3.0</a></div></div>
        </div>
      </div>
    </div>

    <!-- Contributors -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">开发者</h2>
      <div class="space-y-3">
        {CONTRIBUTORS.map(c => (
          <div class="flex items-center gap-3">
            <img src={`/avatars/${c.name}.png`} alt={c.name} class="size-10 rounded-full object-cover" />
            <div class="min-w-0 flex-1">
              <div class="text-sm font-medium">{c.name}</div>
              <div class="text-xs text-muted-foreground">{c.role}</div>
            </div>
            <a href={c.url} target="_blank" class="inline-flex h-7 items-center gap-1.5 rounded-md px-2.5 text-xs font-medium transition-colors hover:bg-accent hover:text-accent-foreground">
              <Icon name="fa6-brands:github" class="size-3" />GitHub
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Services -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">
        <Icon name="lucide:heart" class="mr-1.5 inline size-4 align-text-bottom text-destructive" />鸣谢
      </h2>
      <div class="grid grid-cols-1 gap-1 sm:grid-cols-2">
        {SERVICES.map(svc => {
          const ext = svc.name === 'Modrinth' ? 'svg' : 'png'
          const file = svc.name === 'Minecraft 官网' ? 'minecraft' : svc.name.toLowerCase()
          return (
          <a href={svc.url} target="_blank" class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm transition-colors hover:bg-accent">
            <img src={`/services/${file}.${ext}`} alt={svc.name} class="size-6 shrink-0 rounded object-contain" />
            <div class="min-w-0 flex-1">
              <div class="font-medium">{svc.name}</div>
              <div class="truncate text-xs text-muted-foreground">{svc.desc}</div>
            </div>
            <Icon name="lucide:external-link" class="size-3 shrink-0 text-muted-foreground/50" />
          </a>
          )
        })}
      </div>
    </div>

    <!-- References -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">参考项目</h2>
      <div class="space-y-1">
        {REFERENCES.map(r => (
          <a href={r.url} target="_blank" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors hover:bg-accent">
            <Icon name="fa6-brands:github" class="size-4 shrink-0 text-muted-foreground" />
            <div class="min-w-0 flex-1">
              <div class="font-medium">{r.name}</div>
              <div class="truncate text-xs text-muted-foreground">{r.desc}</div>
            </div>
            <Icon name="lucide:external-link" class="size-3 shrink-0 text-muted-foreground/50" />
          </a>
        ))}
      </div>
    </div>

    <p class="text-center text-xs text-muted-foreground">详细版本信息与依赖列表请在启动器「关于」页面查看。</p>
  </section>
</Base>
