---
import Base from '../layouts/Base.astro';

const releases = [
  { version: '0.1.1', date: '2025-07', changes: ['修复多个 UI 问题', '添加 Vulkan 运行时检查', '优化 macOS DMG 构建'] },
  { version: '0.1.0', date: '2025-06', changes: ['首次公开发布', '支持多版本管理', '支持 Forge/Fabric/Quilt 等加载器', '内置 Modrinth 和 CurseForge 资源浏览', 'Microsoft 账户登录', '内网穿透联机功能'] },
];
---

<Base title="更新日志">
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="mb-8 text-3xl font-bold">更新日志</h1>
    <div class="space-y-6">
      {releases.map(r => (
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
          <div class="mb-3 flex items-baseline gap-3">
            <h2 class="text-lg font-semibold">v{r.version}</h2>
            <span class="text-xs text-[var(--color-muted-fg)]">{r.date}</span>
          </div>
          <ul class="space-y-1 text-sm text-[var(--color-muted-fg)]">
            {r.changes.map(c => <li>• {c}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Base>
