---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

interface TutorialSection {
  id: string
  title: string
  category: string
  html: string
}

const sections: TutorialSection[] = [
  // ── 快速开始 ──
  {
    id: 'download-install',
    title: '下载与安装',
    category: '快速开始',
    html: `<p>从 <a href="/download">下载页面</a> 获取对应系统的安装包。</p>
<img src="/tutorial/download.jpg" alt="下载页面" class="my-3 rounded-lg border border-border" onerror="this.style.display='none'">
<ul class="space-y-2">
  <li><strong>Windows</strong> — 运行 <code>.msi</code> 安装包，按向导完成安装。安装完成后从开始菜单启动。</li>
  <li><strong>macOS</strong> — 挂载 <code>.dmg</code> 文件，将 Qomicex 拖入 Applications 文件夹。首次启动需在「安全性与隐私」中允许打开。</li>
  <li><strong>Linux</strong> — 运行 <code>.AppImage</code>（<code>chmod +x</code> 后直接运行），或通过包管理器安装 <code>.deb</code> / <code>.rpm</code> 包。</li>
</ul>
<p>启动器首次运行时会自动检测 Java 环境并引导初始设置。</p>`,
  },
  {
    id: 'setup-java',
    title: '设置 Java 运行时',
    category: '快速开始',
    html: `<p>Qomicex 需要 Java 17 或更高版本。首次启动时启动器会自动检测系统中的 Java。你也可以在设置中手动配置：</p>
<ol class="space-y-2">
  <li>点击侧边栏的「设置」进入设置页面。</li>
  <li>在「Java 运行时」部分，点击「浏览」手动选择 Java 可执行文件路径。</li>
  <li>或点击「下载 Java」让启动器自动下载并配置一个兼容的 Java 版本。</li>
  <li>你还可以为每个游戏实例单独指定 Java 参数（如内存分配、JVM 参数等）。</li>
</ol>
<div class="mt-3 rounded-lg border border-yellow-500/20 bg-yellow-500/5 px-4 py-3 text-sm">
  <strong>提示：</strong>建议为大型 Mod 包分配 4GB 以上内存。你可以在实例设置中调整 <code>-Xmx</code> 参数。
</div>`,
  },
  {
    id: 'add-account',
    title: '添加账户',
    category: '快速开始',
    html: `<p>点击侧边栏的「账户」进入账户管理页面。Qomicex 支持三种登录方式：</p>
<div class="mt-3 grid gap-3 sm:grid-cols-3">
  <div class="rounded-lg border border-border bg-card p-4">
    <div class="mb-1 font-semibold text-sm">Microsoft</div>
    <p class="text-xs text-muted-foreground">正版 Minecraft 账户。点击「登录 Microsoft 账户」按浏览器提示完成授权。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-4">
    <div class="mb-1 font-semibold text-sm">离线账户</div>
    <p class="text-xs text-muted-foreground">无需正版账号。输入任意用户名即可创建离线档案。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-4">
    <div class="mb-1 font-semibold text-sm">外置登录</div>
    <p class="text-xs text-muted-foreground">兼容 Authlib-Injector 协议的认证服务器。输入服务器地址和凭据即可。</p>
  </div>
</div>
<img src="/tutorial/accounts.jpg" alt="账户管理" class="my-3 rounded-lg border border-border" onerror="this.style.display='none'">`,
  },
  {
    id: 'install-instance',
    title: '安装游戏实例',
    category: '快速开始',
    html: `<p>游戏实例是 Qomicex 的核心概念，每个实例代表一个独立的 Minecraft 安装。</p>
<ol class="space-y-2">
  <li>点击侧边栏的「实例」进入实例列表页面。</li>
  <li>点击「创建实例」按钮。</li>
  <li>选择 Minecraft 版本（支持 1.6 至最新版本，包括快照）。</li>
  <li>选择模组加载器：Forge、Fabric、Quilt、NeoForge 或 OptiFine。</li>
  <li>选择加载器版本（启动器会自动推荐兼容版本）。</li>
  <li>点击「安装」，启动器将自动下载所需文件并创建实例。</li>
</ol>
<img src="/tutorial/create-instance.jpg" alt="创建实例" class="my-3 rounded-lg border border-border" onerror="this.style.display='none'">
<p class="text-sm text-muted-foreground">安装完成后，实例卡片上会显示版本信息和已安装的加载器图标。点击实例即可进入详情页面。</p>`,
  },

  // ── 核心功能 ──
  {
    id: 'manage-mods',
    title: '管理模组与资源',
    category: '核心功能',
    html: `<p>在实例详情页可以管理该实例的所有资源文件。</p>
<div class="mt-3 grid gap-3 sm:grid-cols-2">
  <div class="rounded-lg border border-border bg-card p-4">
    <h4 class="mb-1 text-sm font-semibold">📦 模组 (Mods)</h4>
    <p class="text-xs text-muted-foreground">添加、删除或禁用模组。支持 Jar-in-Jar 和模组文件夹加载。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-4">
    <h4 class="mb-1 text-sm font-semibold">🎨 资源包</h4>
    <p class="text-xs text-muted-foreground">管理材质包和资源包，实时预览并调整加载顺序。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-4">
    <h4 class="mb-1 text-sm font-semibold">☀️ 光影包</h4>
    <p class="text-xs text-muted-foreground">安装和管理光影包（需要 OptiFine 或 Iris 兼容加载器）。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-4">
    <h4 class="mb-1 text-sm font-semibold">📜 数据包</h4>
    <p class="text-xs text-muted-foreground">管理世界数据包，可以在实例级别预安装。</p>
  </div>
</div>
<p class="mt-3">所有资源页面都内置了搜索和排序功能，方便快速定位。</p>`,
  },
  {
    id: 'resource-center',
    title: '资源中心',
    category: '核心功能',
    html: `<p>资源中心是一个一站式资源浏览器，让你无需离开启动器即可搜索和安装各种 Minecraft 资源。</p>
<h4 class="mt-4 mb-2 font-semibold">支持的平台</h4>
<ul class="space-y-1">
  <li><strong>Modrinth</strong> — 搜索和浏览 Modrinth 平台上的模组、资源包、光影包和数据包。</li>
  <li><strong>CurseForge</strong> — 访问 CurseForge 的海量资源库。</li>
  <li><strong>Mcmod 百科</strong> — 中文模组百科，提供详细的模组介绍和下载链接。</li>
  <li><strong>FTB</strong> — 浏览和安装 FTB 整合包。</li>
</ul>
<h4 class="mt-4 mb-2 font-semibold">使用方法</h4>
<ol class="space-y-1">
  <li>点击侧边栏的「资源中心」进入。</li>
  <li>在搜索框输入关键词，选择平台和资源类型。</li>
  <li>浏览结果列表，点击资源查看详情。</li>
  <li>在详情页点击「安装到实例」，选择目标实例即可一键安装。</li>
</ol>
<img src="/tutorial/resource-center.jpg" alt="资源中心" class="my-3 rounded-lg border border-border" onerror="this.style.display='none'">`,
  },
  {
    id: 'launch-game',
    title: '启动游戏',
    category: '核心功能',
    html: `<p>在实例详情页确认配置无误后，点击「启动」按钮即可启动游戏。</p>
<ol class="space-y-2">
  <li>检查 Java 路径和内存分配是否合适。</li>
  <li>确认已选择正确的账户。</li>
  <li>可选：在「游戏设置」中调整分辨率、JVM 参数等。</li>
  <li>点击「启动」，启动器会实时显示启动进度日志。</li>
</ol>
<div class="mt-3 rounded-lg border border-blue-500/20 bg-blue-500/5 px-4 py-3 text-sm">
  <strong>提示：</strong>启动过程中的日志可以帮助排查问题。如果游戏启动失败，可以查看「日志分析」功能获取错误诊断。
</div>
<p class="mt-3">游戏窗口出现后，启动器会自动转入后台运行监控。你可以在「运行中」页面查看和管理正在运行的游戏实例，包括内存使用情况和强制停止。</p>`,
  },
  {
    id: 'lan-play',
    title: '联机功能',
    category: '核心功能',
    html: `<p>Qomicex 集成了基于 EasyTier 的内网穿透联机功能，让你无需公网 IP 或端口转发即可与好友畅玩。</p>
<h4 class="mt-4 mb-2 font-semibold">创建联机房间</h4>
<ol class="space-y-1">
  <li>在「联机」页面点击「创建房间」。</li>
  <li>选择需要联机的游戏实例。</li>
  <li>启动器会自动建立虚拟网络连接。</li>
  <li>将房间码分享给好友即可。</li>
</ol>
<h4 class="mt-4 mb-2 font-semibold">加入联机房间</h4>
<ol class="space-y-1">
  <li>在「联机」页面点击「加入房间」。</li>
  <li>输入好友分享的房间码。</li>
  <li>连接成功后，好友的虚拟 IP 会显示在列表中。</li>
  <li>在 Minecraft 多人游戏中添加该 IP 即可加入。</li>
</ol>
<div class="mt-3 rounded-lg border border-yellow-500/20 bg-yellow-500/5 px-4 py-3 text-sm">
  <strong>注意：</strong>所有参与者都需要安装 Qomicex 启动器并进入联机页面。联机性能取决于网络状况。
</div>`,
  },
  {
    id: 'version-isolation',
    title: '版本隔离',
    category: '核心功能',
    html: `<p>版本隔离功能让每个游戏实例拥有独立的配置文件和资源目录，互不干扰。</p>
<h4 class="mt-4 mb-2 font-semibold">隔离的内容</h4>
<div class="grid gap-2 sm:grid-cols-3 text-sm">
  <div class="rounded-lg border border-border bg-card px-3 py-2">mods/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">saves/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">resourcepacks/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">shaderpacks/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">screenshots/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">datapacks/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">crash-reports/</div>
  <div class="rounded-lg border border-border bg-card px-3 py-2">servers.dat</div>
</div>
<h4 class="mt-4 mb-2 font-semibold">开启方法</h4>
<p>在创建实例时，勾选「启用版本隔离」选项。已创建的实例可以在实例设置中找到该选项并开启。共享目录（versions、assets、libraries 等）始终位于 .minecraft 根目录，不会被隔离。</p>`,
  },
]
---

<Base title="使用教程">
  <div class="mx-auto flex max-w-5xl gap-8 px-4 py-10">
    <!-- Sidebar -->
    <nav class="hidden w-52 shrink-0 md:block">
      <div class="sticky top-4 space-y-4">
        {[...new Set(sections.map(s => s.category))].map(cat => (
          <div>
            <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">{cat}</p>
            <ul class="space-y-0.5">
              {sections.filter(s => s.category === cat).map(s => (
                <li>
                  <a href={`#${s.id}`} class="block rounded-md px-3 py-1.5 text-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </nav>

    <!-- Content -->
    <article class="min-w-0 flex-1">
      <h1 class="mb-8 text-3xl font-bold">使用教程</h1>
      <div class="space-y-10">
        {sections.map((s, i) => (
          <section id={s.id} class="scroll-mt-20">
            <div class="mb-1 flex items-center gap-2">
              {i > 0 && <span class="h-px flex-1 bg-border"></span>}
            </div>
            <h2 class="mb-3 text-xl font-semibold">{s.title}</h2>
            <div class="space-y-3 text-sm leading-relaxed text-muted-foreground [&_strong]:text-foreground [&_code]:rounded [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-xs [&_code]:font-mono [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_ol]:ml-5 [&_ul]:ml-5 [&_li]:leading-relaxed" set:html={s.html} />
          </section>
        ))}
      </div>

      <!-- Feedback -->
      <div class="mt-12 rounded-xl border border-border bg-card p-5">
        <h3 class="mb-1 font-semibold">需要帮助？</h3>
        <p class="text-sm text-muted-foreground">如果教程未能解决你的问题，请通过 <a href="https://github.com/Qomicex-Public/Qomicex.Tauri/issues" target="_blank" class="text-primary underline underline-offset-2">GitHub Issues</a> 或 <a href="https://qm.qq.com/q/rKiwzrkg8w" target="_blank" class="text-primary underline underline-offset-2">QQ 群</a> 反馈。</p>
      </div>
    </article>

    <!-- On this page (right sidebar for desktop) -->
    <nav class="hidden w-44 shrink-0 lg:block">
      <div class="sticky top-4">
        <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">本页内容</p>
        <ul class="space-y-0.5 text-sm">
          {sections.map(s => (
            <li>
              <a href={`#${s.id}`} class="block truncate rounded-md px-3 py-1 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>
</Base>

<script>
  // Highlight current section in sidebar on scroll
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        document.querySelectorAll('nav a').forEach(function (a) {
          a.classList.remove('bg-accent', 'text-accent-foreground')
        })
        var link = document.querySelector('nav a[href="#' + entry.target.id + '"]')
        if (link) link.classList.add('bg-accent', 'text-accent-foreground')
      }
    })
  }, { rootMargin: '-80px 0px -60% 0px' })

  document.querySelectorAll('section[id]').forEach(function (el) { observer.observe(el) })
</script>
