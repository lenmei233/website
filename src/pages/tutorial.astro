---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

interface TutorialPage {
  id: string
  title: string
  category: string
  html: string
}

const pages: TutorialPage[] = [
  {
    id: 'download-install',
    title: '下载与安装',
    category: '快速开始',
    html: `<p>从 <a href="/download">下载页面</a> 获取对应系统的安装包。</p>
<img src="/tutorial/download.jpg" alt="下载页面" class="my-3 rounded-lg border border-border" onerror="this.style.display='none'">
<ul class="space-y-2">
  <li><strong>Windows</strong> — 运行 <code>.msi</code> 安装包，按向导完成安装。</li>
  <li><strong>macOS</strong> — 挂载 <code>.dmg</code>，将 Qomicex 拖入 Applications 文件夹。</li>
  <li><strong>Linux</strong> — 运行 <code>.AppImage</code>（<code>chmod +x</code> 后运行），或安装 <code>.deb</code> / <code>.rpm</code> 包。</li>
</ul>
<p>首次运行时会自动检测 Java 并引导初始设置。</p>`,
  },
  {
    id: 'setup-java',
    title: '设置 Java',
    category: '快速开始',
    html: `<p>Qomicex 需要 Java 17 或更高版本。</p>
<ol class="space-y-2">
  <li>进入「设置」→「Java 运行时」。</li>
  <li>点击「浏览」手动选择 Java 路径，或点击「下载 Java」自动安装。</li>
  <li>每个实例可单独设置 JVM 参数（如 <code>-Xmx</code> 内存上限）。</li>
</ol>
<div class="rounded-lg border border-yellow-500/20 bg-yellow-500/5 px-4 py-3 text-sm">建议为大型 Mod 包分配 4GB 以上内存。</div>`,
  },
  {
    id: 'add-account',
    title: '添加账户',
    category: '快速开始',
    html: `<p>进入「账户」页面，Qomicex 支持三种登录方式：</p>
<div class="grid gap-3 sm:grid-cols-3">
  <div class="rounded-lg border border-border bg-card p-3">
    <div class="mb-1 font-semibold text-sm">Microsoft</div>
    <p class="text-xs text-muted-foreground">正版登录，按浏览器提示完成授权。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-3">
    <div class="mb-1 font-semibold text-sm">离线账户</div>
    <p class="text-xs text-muted-foreground">输入任意用户名即可创建。</p>
  </div>
  <div class="rounded-lg border border-border bg-card p-3">
    <div class="mb-1 font-semibold text-sm">外置登录</div>
    <p class="text-xs text-muted-foreground">兼容 Authlib-Injector 认证服务器。</p>
  </div>
</div>`,
  },
  {
    id: 'install-instance',
    title: '安装游戏实例',
    category: '快速开始',
    html: `<ol class="space-y-2">
  <li>进入「实例」页面，点击「创建实例」。</li>
  <li>选择 Minecraft 版本（支持 1.6 至最新版）。</li>
  <li>选择加载器：Forge、Fabric、Quilt、NeoForge 或 OptiFine。</li>
  <li>选择加载器版本（自动推荐兼容版本）。</li>
  <li>点击「安装」，启动器自动下载所需文件。</li>
</ol>
<img src="/tutorial/create-instance.jpg" alt="创建实例" class="my-3 rounded-lg border border-border" onerror="this.style.display='none'">`,
  },
  {
    id: 'manage-mods',
    title: '管理模组与资源',
    category: '核心功能',
    html: `<p>在实例详情页管理所有资源：</p>
<div class="grid gap-2 sm:grid-cols-2">
  <div class="rounded-lg border border-border bg-card p-3"><strong>模组</strong><br><span class="text-xs text-muted-foreground">添加、删除、禁用，支持 Jar-in-Jar。</span></div>
  <div class="rounded-lg border border-border bg-card p-3"><strong>资源包</strong><br><span class="text-xs text-muted-foreground">管理材质资源，调整加载顺序。</span></div>
  <div class="rounded-lg border border-border bg-card p-3"><strong>光影包</strong><br><span class="text-xs text-muted-foreground">需 OptiFine 或 Iris 兼容加载器。</span></div>
  <div class="rounded-lg border border-border bg-card p-3"><strong>数据包</strong><br><span class="text-xs text-muted-foreground">实例级别预安装数据包。</span></div>
</div>`,
  },
  {
    id: 'resource-center',
    title: '资源中心',
    category: '核心功能',
    html: `<p>一站式资源浏览器，无需离开启动器即可搜索安装。</p>
<h4 class="mt-3 mb-2 font-semibold text-sm">支持平台</h4>
<ul class="space-y-1">
  <li><strong>Modrinth</strong> — 模组、资源包、光影包。</li>
  <li><strong>CurseForge</strong> — 海量资源库。</li>
  <li><strong>Mcmod 百科</strong> — 中文模组数据库。</li>
  <li><strong>FTB</strong> — 整合包。</li>
</ul>
<h4 class="mt-3 mb-2 font-semibold text-sm">使用方法</h4>
<ol class="space-y-1">
  <li>进入「资源中心」，输入关键词搜索。</li>
  <li>选择平台和资源类型过滤。</li>
  <li>点击资源查看详情，然后「安装到实例」。</li>
</ol>`,
  },
  {
    id: 'launch-game',
    title: '启动游戏',
    category: '核心功能',
    html: `<ol class="space-y-2">
  <li>确认 Java 路径和内存分配无误。</li>
  <li>确认已选择正确账户。</li>
  <li>点击「启动」，实时查看启动进度日志。</li>
</ol>
<div class="rounded-lg border border-blue-500/20 bg-blue-500/5 px-4 py-3 text-sm">启动日志可帮助排查问题。如果启动失败，使用「日志分析」功能诊断。</div>
<p class="mt-3">游戏窗口出现后，启动器自动转入后台。「运行中」页面可管理正在运行的实例。</p>`,
  },
  {
    id: 'lan-play',
    title: '联机功能',
    category: '核心功能',
    html: `<p>基于 EasyTier 的内网穿透联机，无需公网 IP 或端口转发。</p>
<div class="grid gap-3 sm:grid-cols-2">
  <div class="rounded-lg border border-border bg-card p-3">
    <h4 class="mb-1 font-semibold text-sm">创建房间</h4>
    <ol class="text-xs text-muted-foreground space-y-0.5 ml-4">
      <li>进入「联机」→「创建房间」。</li>
      <li>选择游戏实例，自动建立连接。</li>
      <li>将房间码分享给好友。</li>
    </ol>
  </div>
  <div class="rounded-lg border border-border bg-card p-3">
    <h4 class="mb-1 font-semibold text-sm">加入房间</h4>
    <ol class="text-xs text-muted-foreground space-y-0.5 ml-4">
      <li>进入「联机」→「加入房间」。</li>
      <li>输入房间码。</li>
      <li>在 MC 多人游戏连接虚拟 IP。</li>
    </ol>
  </div>
</div>`,
  },
  {
    id: 'version-isolation',
    title: '版本隔离',
    category: '核心功能',
    html: `<p>让每个实例拥有独立的配置文件目录，互不干扰。</p>
<p class="text-sm text-muted-foreground">隔离内容：<code>mods</code>、<code>saves</code>、<code>resourcepacks</code>、<code>shaderpacks</code>、<code>screenshots</code>、<code>datapacks</code>、<code>crash-reports</code>、<code>servers.dat</code></p>
<p class="mt-3">在创建实例时勾选「启用版本隔离」，或之后在实例设置中开启。</p>`,
  },
]
---

<Base title="使用教程">
  <div class="mx-auto flex max-w-4xl gap-8 px-4 py-10">
    <!-- Sidebar -->
    <nav class="hidden w-48 shrink-0 md:block">
      <div class="sticky top-4 space-y-4">
        {[...new Set(pages.map(p => p.category))].map(cat => (
          <div>
            <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">{cat}</p>
            <ul class="space-y-0.5">
              {pages.filter(p => p.category === cat).map((p, i) => (
                <li>
                  <button data-page={pages.indexOf(p)} class="page-nav w-full rounded-md px-3 py-1.5 text-left text-sm transition-colors hover:bg-accent hover:text-accent-foreground">{p.title}</button>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </nav>

    <!-- Content -->
    <article class="min-w-0 flex-1">
      <h1 class="mb-6 text-3xl font-bold">使用教程</h1>

      {pages.map((p, i) => (
        <div id={"page-" + i} class={"page-content " + (i === 0 ? '' : 'hidden')}>
          <div class="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
            <span class="rounded bg-primary/10 px-2 py-0.5 font-medium text-primary">{p.category}</span>
            <span>{i + 1} / {pages.length}</span>
          </div>
          <h2 class="mb-4 text-xl font-semibold">{p.title}</h2>
          <div class="space-y-3 text-sm leading-relaxed text-muted-foreground [&_strong]:text-foreground [&_code]:rounded [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-xs [&_code]:font-mono [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_ol]:ml-5 [&_ul]:ml-5 [&_li]:leading-relaxed" set:html={p.html} />

          <!-- Prev / Next -->
          <div class="mt-8 flex items-center justify-between border-t border-border pt-4">
            <button data-page={i - 1} class={"page-nav inline-flex h-9 items-center gap-1.5 rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground " + (i === 0 ? 'invisible' : '')}>
              <Icon name="lucide:chevron-left" class="size-4" />上一页
            </button>
            <div class="flex items-center gap-1.5">
              {pages.map((_, j) => (
                <button data-page={j} class={"page-dot size-2 rounded-full transition-colors " + (j === i ? 'bg-primary' : 'bg-border hover:bg-muted-foreground/30')} aria-label={"第 " + (j + 1) + " 页"} />
              ))}
            </div>
            <button data-page={i + 1} class={"page-nav inline-flex h-9 items-center gap-1.5 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 " + (i === pages.length - 1 ? 'invisible' : '')}>
              下一页<Icon name="lucide:chevron-right" class="size-4" />
            </button>
          </div>
        </div>
      ))}

      <!-- Feedback -->
      <div class="mt-8 rounded-xl border border-border bg-card p-5">
        <h3 class="mb-1 font-semibold">需要帮助？</h3>
        <p class="text-sm text-muted-foreground">请通过 <a href="https://github.com/Qomicex-Public/Qomicex.Tauri/issues" target="_blank" class="text-primary underline underline-offset-2">GitHub Issues</a> 或 <a href="https://qm.qq.com/q/rKiwzrkg8w" target="_blank" class="text-primary underline underline-offset-2">QQ 群</a> 反馈。</p>
      </div>
    </article>
  </div>
</Base>

<script define:vars={{ pageCount: pages.length }}>
  function showPage(i) {
    document.querySelectorAll('.page-content').forEach(function (el) { el.classList.add('hidden') })
    var page = document.getElementById('page-' + i)
    if (page) page.classList.remove('hidden')
    document.querySelectorAll('.page-dot').forEach(function (d, j) {
      d.className = (j === i ? 'bg-primary' : 'bg-border hover:bg-muted-foreground/30') + ' size-2 rounded-full transition-colors'
    })
    document.querySelectorAll('.page-nav').forEach(function (btn) {
      btn.classList.remove('bg-accent', 'text-accent-foreground')
    })
    var activeNav = document.querySelector('.page-nav[data-page="' + i + '"]')
    if (activeNav) activeNav.classList.add('bg-accent', 'text-accent-foreground')
  }

  document.querySelectorAll('.page-nav, .page-dot').forEach(function (el) {
    el.addEventListener('click', function () {
      var i = parseInt(this.dataset.page)
      if (!isNaN(i) && i >= 0 && i < pageCount) showPage(i)
    })
  })
</script>
