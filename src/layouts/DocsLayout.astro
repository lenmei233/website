---
import Base from './Base.astro';
import { Icon } from 'astro-icon/components';
import { docGroups, flatDocs } from '../data/docs.ts';

const { current, title } = Astro.props as { current: string; title?: string }
const all = flatDocs()
const idx = all.findIndex(d => d.id === current)
const prev = idx > 0 ? all[idx - 1] : null
const next = idx < all.length - 1 ? all[idx + 1] : null
const pageTitle = title ?? all.find(d => d.id === current)?.title ?? '文档'
---

<Base title={pageTitle + ' - 文档'}>
  <div class="mx-auto flex max-w-5xl gap-8 px-4 py-10">
    <nav class="hidden w-52 shrink-0 md:block">
      <div class="sticky top-4 max-h-[calc(100vh-3rem)] space-y-4 overflow-y-auto">
        {docGroups.map(group => (
          <div>
            <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">{group.category}</p>
            <ul class="space-y-0.5">
              {group.items.map(item => (
                <li>
                  <a href={`/docs/${item.id}/`} class={"block rounded-md px-3 py-1.5 text-sm transition-colors " + (item.id === current ? 'bg-accent font-medium text-accent-foreground' : 'hover:bg-accent hover:text-accent-foreground')}>
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </nav>

    <article class="min-w-0 flex-1">
      <div class="mb-6">
        <a href="/docs/" class="inline-flex items-center gap-1 text-xs text-muted-foreground transition-colors hover:text-foreground">
          <Icon name="lucide:chevron-left" class="size-3" />返回文档首页
        </a>
        {prev && (
          <span class="ml-3 text-xs text-muted-foreground">/</span>
        )}
        {prev && (
          <a href={`/docs/${prev.id}/`} class="ml-3 inline-flex items-center gap-1 text-xs text-muted-foreground transition-colors hover:text-foreground">
            <Icon name="lucide:chevron-left" class="size-3" />{prev.title}
          </a>
        )}
      </div>

      <h1 class="mb-6 text-2xl font-bold">{pageTitle}</h1>

      <div class="space-y-3 text-sm leading-relaxed text-muted-foreground [&_strong]:text-foreground [&_code]:rounded [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-xs [&_code]:font-mono [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_ol]:ml-5 [&_ul]:ml-5 [&_li]:leading-relaxed [&_h4]:text-foreground [&_h4]:font-semibold [&_h4]:text-sm [&_img]:rounded-lg [&_img]:border [&_img]:border-border">
        <slot />
      </div>

      <div class="mt-10 flex items-center justify-between border-t border-border pt-5">
        {prev ? (
          <a href={`/docs/${prev.id}/`} class="inline-flex h-9 items-center gap-1.5 rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
            <Icon name="lucide:chevron-left" class="size-4" />{prev.title}
          </a>
        ) : <div />}
        {next ? (
          <a href={`/docs/${next.id}/`} class="inline-flex h-9 items-center gap-1.5 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
            {next.title}<Icon name="lucide:chevron-right" class="size-4" />
          </a>
        ) : <div />}
      </div>
    </article>
  </div>
</Base>
