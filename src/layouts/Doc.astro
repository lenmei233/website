---
import Base from './Base.astro';

const { title } = Astro.props;
const sidebar = [
  { href: '/', label: '首页' },
  { href: '/download', label: '下载' },
  { href: '/tutorial', label: '使用教程' },
  { href: '/about', label: '关于我们' },
  { href: '/legal/user-agreement', label: '用户协议' },
  { href: '/faq', label: '常见问题' },
  { href: '/changelog', label: '更新日志' },
];
---

<Base title={title}>
  <div class="mx-auto flex w-full max-w-5xl gap-8 px-4 py-10">
    <nav class="hidden w-44 shrink-0 md:block">
      <ul class="space-y-1">
        {sidebar.map(item => (
          <li>
            <a href={item.href} class="block rounded-md px-3 py-2 text-sm transition-colors hover:bg-accent hover:text-accent-foreground">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <article class="min-w-0 flex-1">
      <h1 class="mb-6 text-2xl font-bold">{title}</h1>
      <div class="prose prose-invert max-w-none text-muted-foreground">
        <slot />
      </div>
    </article>
  </div>
</Base>
