---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import { t, langFromPath } from '../i18n';

const lang = langFromPath(Astro.url.pathname)
const pageTitle: string = Astro.props.title ?? t('site.title', lang)
const fullTitle = pageTitle + t('site.titleSuffix', lang)
const desc = Astro.props.desc ?? t('site.description', lang)
const canonical = `https://www.qomicex.top${Astro.url.pathname.replace(/\/$/, '')}/`
const enUrl = lang === 'en' ? canonical : `https://www.qomicex.top/en${Astro.url.pathname}`
const zhUrl = lang === 'zh' ? canonical : `https://www.qomicex.top${Astro.url.pathname.replace(/^\/en/, '')}`
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="description" content={desc} />
    <meta name="keywords" content={t('site.keywords', lang)} />
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content="/og-image.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'zh_CN'} />
    {lang === 'zh' && <meta property="og:locale:alternate" content="en_US" />}
    <Analytics />
    <style is:global>
      .admonition {
        margin: 1.5em 0;
        padding: 1em 1.25em;
        border-left: 4px solid;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        line-height: 1.6;
        color: hsl(var(--foreground));
      }
      .admonition > :first-child { margin-top: 0; }
      .admonition > :last-child { margin-bottom: 0; }
      .admonition.note    { background: hsl(220 70% 50% / 0.12); border-color: hsl(220 70% 50%); }
      .admonition.tip     { background: hsl(142 71% 48% / 0.12); border-color: hsl(142 71% 48%); }
      .admonition.warning { background: hsl(40 90% 50% / 0.12); border-color: hsl(40 90% 50%); }
      .admonition.danger,
      .admonition.caution { background: hsl(0 84% 60% / 0.12); border-color: hsl(0 84% 60%); }
    </style>
    <script>
      if (location.pathname === '/' && navigator.language.startsWith('en')) {
        location.replace('/en/')
      }
    </script>
  </head>
  <body class="bg-background text-foreground">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      const observer = new IntersectionObserver(entries => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('animate-visible'); observer.unobserve(e.target) }
        }
      }, { threshold: 0.1 })
      function observeAnimate() {
        for (const el of document.querySelectorAll('[data-animate]')) observer.observe(el)
      }
      observeAnimate()
      document.addEventListener('astro:page-load', observeAnimate)
    </script>
    <script is:inline>
      function initImageViewer() {
        var imgs = document.querySelectorAll('main img')
        if (!imgs.length) return
        var overlay = document.createElement('div')
        overlay.id = 'img-overlay'
        overlay.innerHTML = '<img alt="">'
        overlay.addEventListener('click', function(e) {
          if (e.target === overlay) hideImg()
        })
        document.body.appendChild(overlay)
        for (var i = 0; i < imgs.length; i++) {
          imgs[i].style.cursor = 'zoom-in'
          imgs[i].addEventListener('click', function() {
            showImg(this.getAttribute('src'))
          })
        }
      }
      function showImg(src) {
        var overlay = document.getElementById('img-overlay')
        if (!overlay) return
        overlay.querySelector('img').setAttribute('src', src)
        overlay.style.display = 'flex'
        document.body.style.overflow = 'hidden'
      }
      function hideImg() {
        var overlay = document.getElementById('img-overlay')
        if (!overlay) return
        overlay.style.display = 'none'
        document.body.style.overflow = ''
        overlay.querySelector('img').removeAttribute('src')
      }
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') hideImg()
      })
      function init() {
        initImageViewer()
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init)
      } else {
        init()
      }
      document.addEventListener('astro:page-load', init)
    </script>
  </body>
</html>
